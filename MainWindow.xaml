                                                            <StackPanel Width="82" HorizontalAlignment="Center">
                                                                <TextBlock x:Name="ElySoundTrebleValue" Text="0" FontSize="11" TextAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
                                                                <Slider x:Name="ElySoundTrebleSlider" Minimum="-12" Maximum="12"
                                                                        Style="{StaticResource VerticalEqSlider}" ValueChanged="ElySoundSlider_Changed"/>
                                                                <TextBlock Text="5.2 kHz" FontSize="11" FontWeight="SemiBold" TextAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                                                <TextBlock Text="aigus" FontSize="10" TextAlignment="Center" Foreground="{DynamicResource FaintBrush}"/>
                                                            </StackPanel>
                                                            <StackPanel Width="82" HorizontalAlignment="Center">
                                                                <TextBlock x:Name="ElySoundClarityValue" Text="0" FontSize="11" TextAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
                                                                <Slider x:Name="ElySoundClaritySlider" Minimum="-6" Maximum="12"
                                                                        Style="{StaticResource VerticalEqSlider}" ValueChanged="ElySoundSlider_Changed"/>
                                                                <TextBlock Text="9.5 kHz" FontSize="11" FontWeight="SemiBold" TextAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                                                <TextBlock Text="air" FontSize="10" TextAlignment="Center" Foreground="{DynamicResource FaintBrush}"/>
                                                            </StackPanel>
                                                        </UniformGrid>
                                                    </Grid>
                                                </Grid>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="54"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Largeur" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                                    <Slider x:Name="ElySoundWidthSlider" Grid.Column="1" Minimum="0" Maximum="60"
                                                            Style="{StaticResource VolumeSlider}" ValueChanged="ElySoundSlider_Changed"/>
                                                    <TextBlock x:Name="ElySoundWidthValue" Grid.Column="2" Text="0"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
                                                </Grid>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="54"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Compression" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                                    <Slider x:Name="ElySoundCompressorSlider" Grid.Column="1" Minimum="0" Maximum="60"
                                                            Style="{StaticResource VolumeSlider}" ValueChanged="ElySoundSlider_Changed"/>
                                                    <TextBlock x:Name="ElySoundCompressorValue" Grid.Column="2" Text="0"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
                                                </Grid>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="76"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Limiteur" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                                    <Slider x:Name="ElySoundLimiterSlider" Grid.Column="1" Minimum="-3" Maximum="-0.3" TickFrequency="0.1"
                                                            Style="{StaticResource VolumeSlider}" ValueChanged="ElySoundSlider_Changed"/>
                                                    <TextBlock x:Name="ElySoundLimiterValue" Grid.Column="2" Text="0"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel x:Name="SettingsElyFlowPanel" Visibility="Collapsed">
                                                <TextBlock Text="ELYFLOW" Margin="0,26,0,6" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                                <TextBlock Text="NVIDIA FRUC produit une image intermédiaire par image source (×2 : 24→48, 30→60). La cible manuelle concerne uniquement le moteur mpv pacing ; demander 120–360 FPS ne crée pas davantage d'images FRUC et gaspillerait du GPU."
                                                           FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource FaintBrush}"/>

                                                <TextBlock x:Name="ElyFlowGateHint" Visibility="Collapsed"
                                                           Text="ELYFLOW nécessite le renderer ELYCORE. Sélectionnez « ELYCORE Renderer » dans Lecture → Backend vidéo pour pouvoir l'activer."
                                                           FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource MutedBrush}"/>

                                                <CheckBox x:Name="ElyFlowEnabledSwitch" Style="{StaticResource Switch}"
                                                          Content="Activer ELYFLOW" Click="ElyFlowSetting_Changed"/>

                                                <Grid Margin="0,16,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="260"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Moteur" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <ComboBox x:Name="ElyFlowEngineCombo" Grid.Column="1" Height="40"
                                                              Style="{StaticResource FieldCombo}"
                                                              SelectionChanged="ElyFlowCombo_Changed">
                                                        <ComboBoxItem Tag="nvidia-fruc" Content="NVIDIA Optical Flow FRUC"/>
                                                        <ComboBoxItem Tag="mpv-pacing" Content="mpv pacing / display-resample"/>
                                                    </ComboBox>
                                                </Grid>

                                                <CheckBox x:Name="ElyFlowRtxVsrSwitch" Margin="0,12,0,2"
                                                          Style="{StaticResource Switch}"
                                                          Content="RTX Video Super Resolution avant FRUC"
                                                          ToolTip="Upscale IA NVIDIA sur D3D11, puis interpolation FRUC à la résolution de sortie."
                                                          Click="ElyFlowSetting_Changed"/>

                                                <Grid Margin="0,10,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="260"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="ElyFlowTargetLabel" Text="FPS cible (mpv pacing)" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <ComboBox x:Name="ElyFlowTargetCombo" Grid.Column="1" Height="40"
                                                              Style="{StaticResource FieldCombo}"
                                                              SelectionChanged="ElyFlowCombo_Changed">
                                                        <ComboBoxItem Tag="30" Content="30 fps"/>
                                                        <ComboBoxItem Tag="60000/1001" Content="59.94 fps"/>
                                                        <ComboBoxItem Tag="60" Content="60 fps"/>
                                                        <ComboBoxItem Tag="120" Content="120 fps"/>
                                                        <ComboBoxItem Tag="144" Content="144 fps"/>
                                                        <ComboBoxItem Tag="165" Content="165 fps"/>
                                                        <ComboBoxItem Tag="240" Content="240 fps"/>
                                                        <ComboBoxItem Tag="360" Content="360 fps"/>
                                                    </ComboBox>
                                                </Grid>

                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="58"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Buffer live post-processing" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <Slider x:Name="ElyFlowLiveBufferSlider" Grid.Column="1"
                                                            Minimum="0.5" Maximum="5" ValueChanged="ElyFlowSlider_Changed"
                                                            Style="{StaticResource VolumeSlider}"/>
                                                    <TextBlock x:Name="ElyFlowLiveBufferValue" Grid.Column="2" Text="5.0s"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource MutedBrush}"/>
                                                </Grid>

                                                <Border Margin="0,18,0,0" Padding="14,12" CornerRadius="8"
                                                        Background="#22000000" BorderBrush="{DynamicResource CardStroke}" BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="Statut NVIDIA FRUC" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextBrush}"/>
                                                        <TextBlock x:Name="ElyFlowStatusText" Margin="0,6,0,0"
                                                                   TextWrapping="Wrap" FontSize="12"
                                                                   Foreground="{DynamicResource FaintBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel x:Name="SettingsSystemPanel" Visibility="Collapsed">

                                            <TextBlock Text="ELYSMART" Margin="0,26,0,6" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource AccentBBrush}"/>
                                            <TextBlock Text="L’ingénieur de performance intégré à ElyCast. Les mesures, détections et estimations restent identifiées séparément."
                                                       Foreground="{DynamicResource FaintBrush}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Usage principal" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                                <ComboBox x:Name="ElySmartProfileCombo" Grid.Column="1" Height="40" Style="{StaticResource FieldCombo}">
                                                    <ComboBoxItem Tag="Iptv" Content="IPTV — stabilité"/><ComboBoxItem Tag="Films" Content="Films — qualité"/>
                                                    <ComboBoxItem Tag="Series" Content="Séries — équilibre"/><ComboBoxItem Tag="Anime" Content="Anime — Anime4K"/>
                                                    <ComboBoxItem Tag="Audio" Content="Audio — visualiseur"/><ComboBoxItem Tag="Mixed" Content="Mixte"/>
                                                </ComboBox>
                                            </Grid>
                                            <CheckBox x:Name="ElySmartNotificationsSwitch" Style="{StaticResource Switch}" Margin="0,12,0,0"
                                                      Content="Afficher les notifications ELYSMART" Click="ElySmartNotificationsSwitch_Click"/>
                                            <CheckBox x:Name="ElySmartAutoSwitch" Style="{StaticResource Switch}" Margin="0,12,0,0"
                                                      Content="Optimisation automatique des effets décoratifs uniquement" Click="ElySmartAutoSwitch_Click"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                                <Button x:Name="ElySmartRunButton" Content="Optimiser automatiquement ElyCast" Style="{StaticResource PrimaryButton}" Width="280" Height="44" Click="ElySmartRun_Click"/>
                                                <Button x:Name="ElySmartCancelButton" Content="Annuler" Style="{StaticResource GhostButton}" Width="100" Height="44" Margin="10,0,0,0" Visibility="Collapsed" Click="ElySmartCancel_Click"/>
                                                <Button x:Name="ElySmartApplyButton" Content="Appliquer" Style="{StaticResource GhostButton}" Width="110" Height="44" Margin="10,0,0,0" Visibility="Collapsed" Click="ElySmartApply_Click"/>
                                                <Button x:Name="ElySmartExportButton" Content="Exporter" Style="{StaticResource GhostButton}" Width="110" Height="44" Margin="10,0,0,0" Click="ElySmartExport_Click"/>
                                            </StackPanel>
                                            <ProgressBar x:Name="ElySmartProgress" Height="7" Margin="0,14,0,0" Minimum="0" Maximum="100" Visibility="Collapsed"/>
                                            <TextBlock x:Name="ElySmartStatusText" Margin="0,10,0,0" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Text="Aucune analyse exécutée."/>
                                            <Border Margin="0,12,0,8" Padding="14" CornerRadius="8" Background="#22000000" BorderBrush="{DynamicResource CardStroke}" BorderThickness="1">
                                                <TextBlock x:Name="ElySmartReportText" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource FaintBrush}" TextWrapping="Wrap" Text="Le rapport détaillé apparaîtra ici."/>
                                            </Border>
                                            <TextBlock Text="DIAGNOSTIC TEMPS RÉEL — 5 MINUTES" Margin="0,18,0,7" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                            <local:ElySmartDiagnosticSurface x:Name="ElySmartDiagnosticGraph" Height="180"/>
                                            <TextBlock x:Name="ElySmartLiveMetricsText" Margin="0,7,0,0" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource FaintBrush}" Text="En attente des premières mesures…"/>

                                             <TextBlock Text="DÉMARRAGE" Margin="0,26,0,6" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                            <CheckBox x:Name="ZapSwitch" Style="{StaticResource Switch}"
                                                      Content="Zapping avec les flèches ↑ ↓" Click="Setting_Changed"/>
                                            <CheckBox x:Name="ConfirmExitSwitch" Style="{StaticResource Switch}"
                                                      Content="Confirmer avant de quitter" Click="Setting_Changed"/>
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="180"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Durée de la console au boot (s)" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextBrush}"/>
                                                <Slider x:Name="BootSlider" Grid.Column="1" Minimum="2" Maximum="12"
                                                        Style="{StaticResource VolumeSlider}" ValueChanged="SliderSetting_Changed"/>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                                                <Button Content="Ouvrir le dossier de données" Style="{StaticResource GhostButton}"
                                                        Height="42" Width="240" Click="OpenDataFolder_Click"/>
                                                <Button Content="Réinitialiser" Style="{StaticResource GhostButton}"
                                                        Height="42" Width="130" Margin="10,0,0,0" Click="ResetSettings_Click"/>
                                            </StackPanel>

                                            <TextBlock Text="À VENIR" Margin="0,28,0,8" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                            <TextBlock Foreground="{DynamicResource FaintBrush}" FontSize="12" TextWrapping="Wrap"
                                                       Text="• Enregistrement du flux &amp; capture d'écran   • Picture-in-Picture / réduction dans la barre des tâches   • Mosaïque multi-flux   • Verrouillage parental par code PIN   • Cache local des logos   • Overlay d'aide raccourcis (?)"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                                </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
