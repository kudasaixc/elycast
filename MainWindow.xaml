                                                                <TextBlock Text="aigus" FontSize="10" TextAlignment="Center" Foreground="{StaticResource FaintBrush}"/>
                                                            </StackPanel>
                                                            <StackPanel Width="82" HorizontalAlignment="Center">
                                                                <TextBlock x:Name="ElySoundClarityValue" Text="0" FontSize="11" TextAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                                                                <Slider x:Name="ElySoundClaritySlider" Minimum="-6" Maximum="12"
                                                                        Style="{StaticResource VerticalEqSlider}" ValueChanged="ElySoundSlider_Changed"/>
                                                                <TextBlock Text="9.5 kHz" FontSize="11" FontWeight="SemiBold" TextAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                                                                <TextBlock Text="air" FontSize="10" TextAlignment="Center" Foreground="{StaticResource FaintBrush}"/>
                                                            </StackPanel>
                                                        </UniformGrid>
                                                    </Grid>
                                                </Grid>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="54"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Largeur" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                                                    <Slider x:Name="ElySoundWidthSlider" Grid.Column="1" Minimum="0" Maximum="60"
                                                            Style="{StaticResource VolumeSlider}" ValueChanged="ElySoundSlider_Changed"/>
                                                    <TextBlock x:Name="ElySoundWidthValue" Grid.Column="2" Text="0"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                                                </Grid>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="54"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Compression" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                                                    <Slider x:Name="ElySoundCompressorSlider" Grid.Column="1" Minimum="0" Maximum="60"
                                                            Style="{StaticResource VolumeSlider}" ValueChanged="ElySoundSlider_Changed"/>
                                                    <TextBlock x:Name="ElySoundCompressorValue" Grid.Column="2" Text="0"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                                                </Grid>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="54"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Limiteur" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                                                    <Slider x:Name="ElySoundLimiterSlider" Grid.Column="1" Minimum="70" Maximum="100"
                                                            Style="{StaticResource VolumeSlider}" ValueChanged="ElySoundSlider_Changed"/>
                                                    <TextBlock x:Name="ElySoundLimiterValue" Grid.Column="2" Text="0"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel x:Name="SettingsElyFlowPanel" Visibility="Collapsed">
                                                <TextBlock Text="ELYFLOW" Margin="0,26,0,6" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                                <TextBlock Text="NVIDIA FRUC produit une image intermédiaire par image source (×2 : 24→48, 30→60). La cible manuelle concerne uniquement le moteur mpv pacing ; demander 120–360 FPS ne crée pas davantage d'images FRUC et gaspillerait du GPU."
                                                           FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"
                                                           Foreground="{StaticResource FaintBrush}"/>

                                                <TextBlock x:Name="ElyFlowGateHint" Visibility="Collapsed"
                                                           Text="ELYFLOW nécessite le renderer ELYCORE. Sélectionnez « ELYCORE Renderer » dans Lecture → Backend vidéo pour pouvoir l'activer."
                                                           FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"
                                                           Foreground="{StaticResource MutedBrush}"/>

                                                <CheckBox x:Name="ElyFlowEnabledSwitch" Style="{StaticResource Switch}"
                                                          Content="Activer ELYFLOW" Click="ElyFlowSetting_Changed"/>

                                                <Grid Margin="0,16,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="260"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Moteur" VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextBrush}"/>
                                                    <ComboBox x:Name="ElyFlowEngineCombo" Grid.Column="1" Height="40"
                                                              Style="{StaticResource FieldCombo}"
                                                              SelectionChanged="ElyFlowCombo_Changed">
                                                        <ComboBoxItem Tag="nvidia-fruc" Content="NVIDIA Optical Flow FRUC"/>
                                                        <ComboBoxItem Tag="mpv-pacing" Content="mpv pacing / display-resample"/>
                                                    </ComboBox>
                                                </Grid>

                                                <CheckBox x:Name="ElyFlowRtxVsrSwitch" Margin="0,12,0,2"
                                                          Style="{StaticResource Switch}"
                                                          Content="RTX Video Super Resolution avant FRUC"
                                                          ToolTip="Upscale IA NVIDIA sur D3D11, puis interpolation FRUC à la résolution de sortie."
                                                          Click="ElyFlowSetting_Changed"/>

                                                <Grid Margin="0,10,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="260"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="ElyFlowTargetLabel" Text="FPS cible (mpv pacing)" VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextBrush}"/>
                                                    <ComboBox x:Name="ElyFlowTargetCombo" Grid.Column="1" Height="40"
                                                              Style="{StaticResource FieldCombo}"
                                                              SelectionChanged="ElyFlowCombo_Changed">
                                                        <ComboBoxItem Tag="30" Content="30 fps"/>
                                                        <ComboBoxItem Tag="60000/1001" Content="59.94 fps"/>
                                                        <ComboBoxItem Tag="60" Content="60 fps"/>
                                                        <ComboBoxItem Tag="120" Content="120 fps"/>
                                                        <ComboBoxItem Tag="144" Content="144 fps"/>
                                                        <ComboBoxItem Tag="165" Content="165 fps"/>
                                                        <ComboBoxItem Tag="240" Content="240 fps"/>
                                                        <ComboBoxItem Tag="360" Content="360 fps"/>
                                                    </ComboBox>
                                                </Grid>

                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="58"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Buffer live post-processing" VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextBrush}"/>
                                                    <Slider x:Name="ElyFlowLiveBufferSlider" Grid.Column="1"
                                                            Minimum="0.5" Maximum="5" ValueChanged="ElyFlowSlider_Changed"
                                                            Style="{StaticResource VolumeSlider}"/>
                                                    <TextBlock x:Name="ElyFlowLiveBufferValue" Grid.Column="2" Text="5.0s"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                                               Foreground="{StaticResource MutedBrush}"/>
                                                </Grid>

                                                <Border Margin="0,18,0,0" Padding="14,12" CornerRadius="8"
                                                        Background="#22000000" BorderBrush="{StaticResource CardStroke}" BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="Statut NVIDIA FRUC" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextBrush}"/>
                                                        <TextBlock x:Name="ElyFlowStatusText" Margin="0,6,0,0"
                                                                   TextWrapping="Wrap" FontSize="12"
                                                                   Foreground="{StaticResource FaintBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel x:Name="SettingsSystemPanel" Visibility="Collapsed">

                                             <TextBlock Text="DÉMARRAGE" Margin="0,26,0,6" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                            <CheckBox x:Name="ZapSwitch" Style="{StaticResource Switch}"
                                                      Content="Zapping avec les flèches ↑ ↓" Click="Setting_Changed"/>
                                            <CheckBox x:Name="ConfirmExitSwitch" Style="{StaticResource Switch}"
                                                      Content="Confirmer avant de quitter" Click="Setting_Changed"/>
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="180"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Durée de la console au boot (s)" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextBrush}"/>
                                                <Slider x:Name="BootSlider" Grid.Column="1" Minimum="2" Maximum="12"
                                                        Style="{StaticResource VolumeSlider}" ValueChanged="SliderSetting_Changed"/>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                                                <Button Content="Ouvrir le dossier de données" Style="{StaticResource GhostButton}"
                                                        Height="42" Width="240" Click="OpenDataFolder_Click"/>
                                                <Button Content="Réinitialiser" Style="{StaticResource GhostButton}"
                                                        Height="42" Width="130" Margin="10,0,0,0" Click="ResetSettings_Click"/>
                                            </StackPanel>

                                            <TextBlock Text="À VENIR" Margin="0,28,0,8" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                            <TextBlock Foreground="{StaticResource FaintBrush}" FontSize="12" TextWrapping="Wrap"
                                                       Text="• Enregistrement du flux &amp; capture d'écran   • Picture-in-Picture / réduction dans la barre des tâches   • Mosaïque multi-flux   • Verrouillage parental par code PIN   • Cache local des logos   • Overlay d'aide raccourcis (?)"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                                </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
