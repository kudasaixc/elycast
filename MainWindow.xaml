                                          StrokeThickness="1.8" Stretch="Uniform" Width="15" Height="15"/>
                                </Button>

                                <!-- SERIES EPISODES PANEL -->
                                <Border x:Name="SeriesPanel" Visibility="Collapsed" Background="#F2070309"
                                        Cursor="Arrow"
                                        CornerRadius="18">
                                    <Grid Margin="24">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource IconButton}" Click="CloseSeries_Click">
                                                    <Path Data="M7,1 L2,6 L7,11 M2,6 H12" Stroke="White" StrokeThickness="1.5"
                                                          Stretch="Uniform" Width="16" Height="16"/>
                                                </Button>
                                                <TextBlock x:Name="SeriesPanelTitle" Text="Series" FontSize="20" FontWeight="Bold"
                                                           VerticalAlignment="Center" Margin="14,0,0,0"
                                                           Foreground="{DynamicResource TextBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                        <ComboBox x:Name="SeasonCombo" Grid.Row="1" Margin="0,16,0,12" Width="200"
                                                  HorizontalAlignment="Left" Style="{StaticResource FieldCombo}"
                                                  SelectionChanged="Season_Changed"/>
                                        <ListBox x:Name="EpisodeList" Grid.Row="2" Style="{StaticResource ChannelListBox}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 MouseDoubleClick="Episode_DoubleClick">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="30" Height="30" CornerRadius="8" Background="#33000000">
                                                            <TextBlock Text="{Binding EpisodeNum}" FontWeight="Bold"
                                                                       Foreground="{DynamicResource AccentSoftBrush}" HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{Binding Title}" Margin="12,0,0,0"
                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                   FontSize="13" Foreground="{DynamicResource TextBrush}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <!-- MUSIC DETAIL PANEL (album / artist / genre / playlist drill-down) -->
                                <Border x:Name="MusicPanel" Visibility="Collapsed" Background="#F2070309"
                                        Cursor="Arrow" CornerRadius="18">
                                    <Grid Margin="28,24">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- header: cover + credits + actions -->
                                        <Grid Grid.Row="0" Margin="0,0,0,18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Style="{StaticResource IconButton}" VerticalAlignment="Top"
                                                    Click="CloseMusic_Click" ToolTip="Back">
                                                <Path Data="M7,1 L2,6 L7,11 M2,6 H12" Stroke="White" StrokeThickness="1.5"
                                                      Stretch="Uniform" Width="16" Height="16"/>
                                            </Button>
                                            <Grid Grid.Column="1" Width="164" Height="164" Margin="18,0,0,0">
                                                <Border CornerRadius="14" Background="#33000000">
                                                    <TextBlock x:Name="MusicPanelInitial" Text="♪" FontWeight="Bold" FontSize="56"
                                                               Foreground="{DynamicResource AccentSoftBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Image x:Name="MusicPanelCover" Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Clip>
                                                        <RectangleGeometry Rect="0,0,164,164" RadiusX="14" RadiusY="14"/>
                                                    </Image.Clip>
                                                </Image>
                                            </Grid>
                                            <StackPanel Grid.Column="2" Margin="22,4,0,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="MusicPanelKind" Text="ALBUM" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MutedBrush}"/>
                                                <TextBlock x:Name="MusicPanelTitle" Text="" FontSize="26" FontWeight="Bold"
                                                           TextTrimming="CharacterEllipsis" Margin="0,2,40,0"
                                                           Foreground="{DynamicResource TextBrush}"/>
                                                <TextBlock x:Name="MusicPanelSubtitle" Text="" FontSize="14"
                                                           TextTrimming="CharacterEllipsis" Margin="0,4,40,0"
                                                           Foreground="{DynamicResource MutedBrush}"/>
                                                <TextBlock x:Name="MusicPanelDetail" Text="" FontSize="12" Margin="0,2,0,0"
                                                           Foreground="{DynamicResource FaintBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                                    <Button Style="{StaticResource PrimaryButton}" Height="40" Padding="18,0"
                                                            Click="GroupPlay_Click">
                                                        <StackPanel Orientation="Horizontal" Margin="14,0">
                                                            <Path Data="M 5,3 L 12,8 L 5,13 Z" Fill="White" Stretch="Uniform"
                                                                  Width="12" Height="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Play all" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource GhostButton}" Height="40" Margin="10,0,0,0"
                                                            Click="GroupShuffle_Click">
                                                        <TextBlock Text="Random" Margin="14,0"/>
                                                    </Button>
                                                    <Button Style="{StaticResource GhostButton}" Height="40" Margin="10,0,0,0"
                                                            ToolTip="Add to queue" Click="GroupQueue_Click">
                                                        <TextBlock Text="+ Queue" Margin="14,0"/>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>

                                        <!-- filter tracks inside the opened group -->
                                        <TextBox x:Name="MusicTrackSearch" Grid.Row="1" Margin="0,0,0,12"
                                                 Style="{StaticResource SearchBox}" Tag="Search this content…"
                                                 TextChanged="MusicTrackSearch_TextChanged"/>

                                        <!-- tracks -->
                                        <ListBox x:Name="MusicTrackList" Grid.Row="2" Style="{StaticResource ChannelListBox}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 VirtualizingStackPanel.IsVirtualizing="True"
                                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                                 PreviewMouseRightButtonDown="ItemList_RightClick"
                                                 MouseDoubleClick="MusicTrack_DoubleClick">
                                            <ListBox.ContextMenu>
                                                <ContextMenu Opened="MusicTrackMenu_Opened">
                                                    <MenuItem Header="Play now" Click="MusicTrackPlay_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="Play next" Click="PlayNext_Click"/>
                                                    <MenuItem Header="Add to queue" Click="AddToQueue_Click"/>
                                                    <MenuItem x:Name="TrackAddPlaylist" Header="Add to playlist"/>
                                                    <Separator/>
                                                    <MenuItem Header="Edit metadata..." Click="EditMetadata_Click"/>
                                                    <MenuItem x:Name="TrackRemoveFromPlaylist" Header="Remove from playlist"
                                                              Click="RemoveFromPlaylist_Click"/>
                                                    <MenuItem Header="Remove from library" Click="RemoveTrack_Click"/>
                                                </ContextMenu>
                                            </ListBox.ContextMenu>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid Width="36" Height="36">
                                                            <Border CornerRadius="9" Background="#33000000">
                                                                <TextBlock Text="{Binding DisplayTrackNumberLabel}" FontWeight="Bold" FontSize="13"
                                                                           Foreground="{DynamicResource AccentSoftBrush}"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <Image Source="{Binding Cover}" Stretch="UniformToFill"
                                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                                <Image.Clip>
                                                                    <RectangleGeometry Rect="0,0,36,36" RadiusX="9" RadiusY="9"/>
                                                                </Image.Clip>
                                                            </Image>
                                                        </Grid>
                                                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                                                       FontSize="13.5" Foreground="{DynamicResource TextBrush}"/>
                                                            <TextBlock Text="{Binding ArtistLine}" TextTrimming="CharacterEllipsis"
                                                                       FontSize="11" Foreground="{DynamicResource FaintBrush}"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding DurationLabel}" FontSize="12"
                                                                   Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"
                                                                   Margin="12,0"/>
                                                        <ToggleButton Grid.Column="3" Style="{StaticResource StarToggle}"
                                                                      VerticalAlignment="Center"
                                                                      IsChecked="{Binding IsFavorite, Mode=TwoWay}"
                                                                      Checked="Fav_Toggle" Unchecked="Fav_Toggle"
                                                                      ToolTip="Favorite"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <!-- SETTINGS PANEL -->
                                <Border x:Name="SettingsPanel" Visibility="Collapsed" Background="#F2070309" CornerRadius="18"
                                        Cursor="Arrow">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
                                        <StackPanel MaxWidth="820" HorizontalAlignment="Left">
                                            <TextBlock Text="Settings" FontSize="24" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextBrush}"/>

                                            <WrapPanel Margin="0,18,0,8">
                                                <Button x:Name="SettingsAppearanceBtn" Tag="appearance" Content="Interface"
                                                        Style="{StaticResource GhostButton}" Width="118" Height="36"
                                                        Margin="0,0,8,8" Click="SettingsCategory_Click"/>
                                                <Button x:Name="SettingsPlaybackBtn" Tag="playback" Content="Playback"
                                                        Style="{StaticResource GhostButton}" Width="110" Height="36"
                                                        Margin="0,0,8,8" Click="SettingsCategory_Click"/>
                                                <Button x:Name="SettingsAudioPlayerBtn" Tag="audio-player" Content="Audio player"
                                                        Style="{StaticResource GhostButton}" Width="140" Height="36"
                                                        Margin="0,0,8,8" Click="SettingsCategory_Click"/>
                                                <Button x:Name="SettingsUpscalingBtn" Tag="upscaling" Content="Upscaling"
                                                        Style="{StaticResource GhostButton}" Width="124" Height="36"
                                                        Margin="0,0,8,8" Click="SettingsCategory_Click"/>
                                                <Button x:Name="SettingsElyColorBtn" Tag="elycolor" Content="ELYCOLOR"
                                                        Style="{StaticResource GhostButton}" Width="124" Height="36"
                                                        Margin="0,0,8,8" Click="SettingsCategory_Click"/>
                                                <Button x:Name="SettingsElySoundBtn" Tag="elysound" Content="ELYSOUND+"
                                                        Style="{StaticResource GhostButton}" Width="132" Height="36"
                                                        Margin="0,0,8,8" Click="SettingsCategory_Click"/>
                                                <Button x:Name="SettingsElyFlowBtn" Tag="elyflow" Content="ELYFLOW"
                                                        Style="{StaticResource GhostButton}" Width="124" Height="36"
                                                        Margin="0,0,8,8" Click="SettingsCategory_Click"/>
                                                <Button x:Name="SettingsSystemBtn" Tag="system" Content="System"
                                                        Style="{StaticResource GhostButton}" Width="112" Height="36"
                                                        Margin="0,0,8,8" Click="SettingsCategory_Click"/>
                                            </WrapPanel>

                                            <StackPanel x:Name="SettingsAppearancePanel">

                                            <Grid Margin="0,24,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="220"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Interface language" FontSize="16" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBlock Text="Changes apply immediately and are saved automatically."
                                                               Margin="0,4,18,0" FontSize="11" Foreground="{DynamicResource FaintBrush}"/>
                                                </StackPanel>
                                                <ComboBox x:Name="LanguageCombo" Grid.Column="1" Height="40"
                                                          Style="{StaticResource FieldCombo}" SelectionChanged="Language_Changed">
                                                    <ComboBoxItem Tag="en" Content="English"/>
                                                    <ComboBoxItem Tag="fr" Content="French"/>
                                                </ComboBox>
                                            </Grid>

                                            <TextBlock Text="ACCENT COLOR" Margin="0,24,0,10" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                            <ItemsControl x:Name="AccentSwatches">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Width="38" Height="38" Margin="0,0,10,10" Cursor="Hand"
                                                                Click="AccentSwatch_Click" Tag="{Binding}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="b" CornerRadius="19" BorderThickness="2"
                                                                            BorderBrush="Transparent"
                                                                            Background="{Binding Converter={StaticResource HexToBrush}}"/>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="b" Property="BorderBrush" Value="White"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBox x:Name="AccentHexBox" Style="{StaticResource FieldBox}" Width="160"
                                                         Height="40" Tag="#FF8B5CF6"/>
                                                <Button Content="Apply" Style="{StaticResource GhostButton}" Height="40"
                                                        Width="110" Margin="8,0,0,0" Click="ApplyHex_Click"/>
                                            </StackPanel>

                                            </StackPanel>

                                            <StackPanel x:Name="SettingsAudioPlayerPanel" Visibility="Collapsed">
                                                <TextBlock Text="AUDIO PLAYER" Margin="0,24,0,6" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                                <Grid Margin="0,8,0,18">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Visualizer renderer" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                                        <TextBlock Text="Switching is immediate. AudioCore+ requires ELYCORE; the classic renderer remains available as a fallback."
                                                                   FontSize="11" Margin="0,4,18,0" TextWrapping="Wrap" Foreground="{DynamicResource FaintBrush}"/>
                                                        <TextBlock x:Name="AudioRendererStatusText" FontSize="11" Margin="0,6,18,0"
                                                                   TextWrapping="Wrap" Foreground="{DynamicResource AccentSoftBrush}"/>
                                                    </StackPanel>
                                                    <ComboBox x:Name="AudioRendererCombo" Grid.Column="1" Height="40"
                                                              Style="{StaticResource FieldCombo}" SelectionChanged="AudioRenderer_Changed">
                                                        <ComboBoxItem Tag="audiocore" Content="ELYCAST AudioCore+"/>
                                                        <ComboBoxItem Tag="classic" Content="Classic (WPF)"/>
                                                    </ComboBox>
                                                </Grid>
                                                <TextBlock Text="Background" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                                <StackPanel Margin="0,10,0,0">
                                                    <RadioButton x:Name="AudioBgSolid" GroupName="audioBackground" Tag="solid"
                                                                 Foreground="{DynamicResource TextBrush}" Checked="AudioVisualizerSetting_Changed">
                                                        <StackPanel Margin="6,0,0,0"><TextBlock Text="Solid" FontWeight="SemiBold"/><TextBlock Text="Dark ElyCast gradient, without an image" FontSize="11" Foreground="{DynamicResource FaintBrush}"/></StackPanel>
                                                    </RadioButton>
                                                    <RadioButton x:Name="AudioBgCover" GroupName="audioBackground" Tag="cover" Margin="0,12,0,0"
                                                                 Foreground="{DynamicResource TextBrush}" Checked="AudioVisualizerSetting_Changed">
                                                        <StackPanel Margin="6,0,0,0"><TextBlock Text="Album artwork" FontWeight="SemiBold"/><TextBlock Text="Enlarge and blur the track's embedded artwork when available" FontSize="11" Foreground="{DynamicResource FaintBrush}"/></StackPanel>
                                                    </RadioButton>
                                                    <RadioButton x:Name="AudioBgImage" GroupName="audioBackground" Tag="image" Margin="0,12,0,0"
                                                                 Foreground="{DynamicResource TextBrush}" Checked="AudioVisualizerSetting_Changed">
                                                        <StackPanel Margin="6,0,0,0"><TextBlock Text="Custom image" FontWeight="SemiBold"/><TextBlock Text="Use one of the five landscapes below" FontSize="11" Foreground="{DynamicResource FaintBrush}"/></StackPanel>
                                                    </RadioButton>
                                                </StackPanel>
                                                <Grid Margin="0,14,0,0">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Image" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                                    <ComboBox x:Name="AudioBackgroundCombo" Grid.Column="1" Height="40" Style="{StaticResource FieldCombo}" SelectionChanged="AudioVisualizerSetting_Changed">
                                                        <ComboBoxItem Tag="mountains" Content="Dolomites"/>
                                                        <ComboBoxItem Tag="sunset" Content="Wild sunset"/>
                                                        <ComboBoxItem Tag="night-sky" Content="Starry sky"/>
                                                        <ComboBoxItem Tag="paris" Content="Paris twilight"/>
                                                        <ComboBoxItem Tag="new-york" Content="Golden New York"/>
                                                    </ComboBox>
                                                </Grid>
                                                <TextBlock Text="Blur intensity" Margin="0,18,0,5" Foreground="{DynamicResource TextBrush}"/>
                                                <Slider x:Name="AudioBlurSlider" Minimum="0" Maximum="48" ValueChanged="AudioVisualizerSlider_Changed"/>
                                                <TextBlock Text="Dimming" Margin="0,14,0,5" Foreground="{DynamicResource TextBrush}"/>
                                                <Slider x:Name="AudioDimSlider" Minimum="15" Maximum="85" ValueChanged="AudioVisualizerSlider_Changed"/>
                                                <TextBlock Text="ANIMATION" Margin="0,22,0,8" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                                <CheckBox x:Name="AudioSlowZoomSwitch" Style="{StaticResource Switch}" Content="Slow zoom" Click="AudioVisualizerSetting_Changed"/>
                                                <CheckBox x:Name="AudioSlowPanSwitch" Style="{StaticResource Switch}" Content="Slow movement" Click="AudioVisualizerSetting_Changed"/>
                                                <CheckBox x:Name="AudioParallaxSwitch" Style="{StaticResource Switch}" Content="Subtle mouse parallax" Click="AudioVisualizerSetting_Changed"/>
                                                <Grid Margin="0,10,0,0">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="Parallax intensity" Foreground="{DynamicResource TextBrush}"/>
                                                        <TextBlock x:Name="AudioParallaxIntensityValue" Text="100%" Margin="0,3,0,0" FontSize="11"
                                                                   Foreground="{DynamicResource FaintBrush}"/>
                                                    </StackPanel>
                                                    <Slider x:Name="AudioParallaxIntensitySlider" Grid.Column="1" Minimum="0" Maximum="200"
                                                            TickFrequency="10" ValueChanged="AudioVisualizerSlider_Changed"/>
                                                </Grid>
                                                <CheckBox x:Name="AudioAutoPaletteSwitch" Style="{StaticResource Switch}" Content="Automatic ELYCOLOR palette" Margin="0,10,0,0" Click="AudioVisualizerSetting_Changed"/>
                                                <CheckBox x:Name="AudioAdaptiveParticlesSwitch" Style="{StaticResource Switch}" Content="Particle colors adapt to the background" Click="AudioVisualizerSetting_Changed"/>
                                                <CheckBox x:Name="AudioShakeSwitch" Style="{StaticResource Switch}" Content="Light bass shake" Click="AudioVisualizerSetting_Changed"/>
                                                <CheckBox x:Name="AudioVSyncSwitch" Style="{StaticResource Switch}" Content="VSync (respect target and synchronize with display)" Click="AudioVisualizerSetting_Changed"/>
                                                <Grid Margin="0,18,0,0">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Visualizer target FPS" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                                    <ComboBox x:Name="AudioFpsCombo" Grid.Column="1" Height="40" Style="{StaticResource FieldCombo}" SelectionChanged="AudioVisualizerSetting_Changed">
                                                        <ComboBoxItem Tag="30" Content="30 FPS (power saving)"/><ComboBoxItem Tag="60" Content="60 FPS"/>
                                                        <ComboBoxItem Tag="120" Content="120 FPS"/><ComboBoxItem Tag="144" Content="144 FPS"/><ComboBoxItem Tag="240" Content="240 FPS"/><ComboBoxItem Tag="360" Content="360 FPS"/><ComboBoxItem Tag="480" Content="480 FPS"/><ComboBoxItem Tag="0" Content="Unlimited"/>
                                                    </ComboBox>
                                                </Grid>
                                                <TextBlock Text="Particle count" Margin="0,18,0,5" Foreground="{DynamicResource TextBrush}"/>
                                                <Slider x:Name="AudioParticleCountSlider" Minimum="24" Maximum="384" TickFrequency="12" IsSnapToTickEnabled="True" ValueChanged="AudioVisualizerSlider_Changed"/>
                                                <TextBlock Text="Particle distance" Margin="0,14,0,5" Foreground="{DynamicResource TextBrush}"/>
                                                <Slider x:Name="AudioParticleDistanceSlider" Minimum="55" Maximum="165" ValueChanged="AudioVisualizerSlider_Changed"/>
                                            </StackPanel>

                                            <StackPanel x:Name="SettingsPlaybackPanel" Visibility="Collapsed">
                                            <TextBlock Text="PLAYBACK" Margin="0,26,0,6" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                            <CheckBox x:Name="StatsSwitch" Style="{StaticResource Switch}"
                                                      Content="Show live statistics" Click="Setting_Changed"/>
                                            <CheckBox x:Name="ReconnectSwitch" Style="{StaticResource Switch}"
                                                      Content="Reconnect automatically if the stream stops" Click="Setting_Changed"/>
                                            <CheckBox x:Name="RememberVolSwitch" Style="{StaticResource Switch}"
                                                      Content="Remember volume" Click="Setting_Changed"/>

                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="260"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Video backend" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBlock Text="mpv GPU targets Direct3D/libplacebo rendering. RTX VSR adds NVIDIA driver AI upscaling (GeForce RTX 20 series or newer, driver 531+). VLC remains the stable fallback."
                                                               FontSize="11" Margin="0,4,16,0" TextWrapping="Wrap"
                                                               Foreground="{DynamicResource FaintBrush}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <ComboBox x:Name="BackendCombo" Height="40"
                                                              Style="{StaticResource FieldCombo}"
                                                              SelectionChanged="BackendSetting_Changed">
                                                        <ComboBoxItem Tag="mpv-gpu" Content="mpv GPU"/>
                                                        <ComboBoxItem Tag="vlc-bitmap" Content="VLC fallback"/>
                                                        <ComboBoxItem Tag="rtx-sdk" Content="mpv GPU + RTX VSR"/>
                                                        <ComboBoxItem Tag="elycore" Content="ELYCORE Renderer"/>
                                                    </ComboBox>
                                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                        <Button x:Name="InstallMpvBtn" Content="Install mpv"
                                                                Style="{StaticResource GhostButton}" Width="116" Height="36"
                                                                Click="InstallMpv_Click"/>
                                                        <TextBlock x:Name="MpvStatusText" Margin="10,0,0,0" VerticalAlignment="Center"
                                                                   FontSize="11" TextWrapping="Wrap" Width="134"
                                                                   Foreground="{DynamicResource FaintBrush}"
                                                                   Text="mpv not verified"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Live stream format" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextBrush}"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <RadioButton x:Name="FormatTs" GroupName="fmt" Content=".ts" Margin="0,0,16,0"
                                                                 Foreground="{DynamicResource TextBrush}" Click="Setting_Changed"/>
                                                    <RadioButton x:Name="FormatM3u" GroupName="fmt" Content=".m3u8"
                                                                 Foreground="{DynamicResource TextBrush}" Click="Setting_Changed"/>
                                                </StackPanel>
                                            </Grid>

                                             <Grid Margin="0,16,0,0">
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="*"/>
                                                     <ColumnDefinition Width="180"/>
                                                 </Grid.ColumnDefinitions>
                                                <TextBlock Text="Default volume" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextBrush}"/>
                                                 <Slider x:Name="DefaultVolSlider" Grid.Column="1" Minimum="0" Maximum="100"
                                                         Style="{StaticResource VolumeSlider}" ValueChanged="SliderSetting_Changed"/>
                                             </Grid>

                                            </StackPanel>

                                            <StackPanel x:Name="SettingsUpscalingPanel" Visibility="Collapsed">
                                             <TextBlock Text="EXTERNAL GPU UPSCALING" Margin="0,26,0,6" FontSize="11"
                                                         FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                             <Grid Margin="0,10,0,0">
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="*"/>
                                                     <ColumnDefinition Width="260"/>
                                                 </Grid.ColumnDefinitions>
                                                 <StackPanel>
