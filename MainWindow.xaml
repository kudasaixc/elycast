                                    <Ellipse Fill="#C9000000" Stroke="#55FFFFFF" StrokeThickness="1">
                                        <Ellipse.Effect><DropShadowEffect Color="#FF000000" BlurRadius="28" ShadowDepth="0" Opacity="0.95"/></Ellipse.Effect>
                                    </Ellipse>
                                    <Path x:Name="CenterTransportIcon" Fill="White" Stretch="Uniform" Width="34" Height="34"
                                          Data="M 4,2 L 11,2 L 11,18 L 4,18 Z M 15,2 L 22,2 L 22,18 L 15,18 Z"/>
                                </Grid>

                                <Button x:Name="CloseOverlayBtn" Visibility="Collapsed"
                                        Panel.ZIndex="50"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,16,16,0" Style="{StaticResource IconButton}"
                                        Click="CloseOverlay_Click" ToolTip="Fermer le panneau">
                                    <Path Data="M 3,3 L 13,13 M 13,3 L 3,13" Stroke="White"
                                          StrokeThickness="1.8" Stretch="Uniform" Width="15" Height="15"/>
                                </Button>

                                <!-- SERIES EPISODES PANEL -->
                                <Border x:Name="SeriesPanel" Visibility="Collapsed" Background="#F2070309"
                                        Cursor="Arrow"
                                        CornerRadius="18">
