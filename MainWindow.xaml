                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="54"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Width" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                                    <Slider x:Name="ElySoundWidthSlider" Grid.Column="1" Minimum="0" Maximum="60"
                                                            Style="{StaticResource VolumeSlider}" ValueChanged="ElySoundSlider_Changed"/>
                                                    <TextBlock x:Name="ElySoundWidthValue" Grid.Column="2" Text="0"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
                                                </Grid>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="54"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Compression" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                                    <Slider x:Name="ElySoundCompressorSlider" Grid.Column="1" Minimum="0" Maximum="60"
                                                            Style="{StaticResource VolumeSlider}" ValueChanged="ElySoundSlider_Changed"/>
                                                    <TextBlock x:Name="ElySoundCompressorValue" Grid.Column="2" Text="0"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
                                                </Grid>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="76"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Limiter" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                                    <Slider x:Name="ElySoundLimiterSlider" Grid.Column="1" Minimum="-3" Maximum="-0.3" TickFrequency="0.1"
                                                            Style="{StaticResource VolumeSlider}" ValueChanged="ElySoundSlider_Changed"/>
                                                    <TextBlock x:Name="ElySoundLimiterValue" Grid.Column="2" Text="0"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel x:Name="SettingsElyFlowPanel" Visibility="Collapsed">
                                                <TextBlock Text="ELYFLOW" Margin="0,26,0,6" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                                <TextBlock Text="NVIDIA FRUC produces one intermediate frame per source frame (2x: 24&gt;48, 30&gt;60). The manual target applies only to mpv pacing; requesting 120-360 FPS does not create additional FRUC frames and would waste GPU resources."
                                                           FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource FaintBrush}"/>

                                                <TextBlock x:Name="ElyFlowGateHint" Visibility="Collapsed"
                                                           Text="ELYFLOW requires the ELYCORE renderer. Select “ELYCORE Renderer” under Playback &gt; Video backend to enable it."
                                                           FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource MutedBrush}"/>

                                                <CheckBox x:Name="ElyFlowEnabledSwitch" Style="{StaticResource Switch}"
                                                          Content="Enable ELYFLOW" Click="ElyFlowSetting_Changed"/>

                                                <Grid Margin="0,16,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="260"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Engine" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <ComboBox x:Name="ElyFlowEngineCombo" Grid.Column="1" Height="40"
                                                              Style="{StaticResource FieldCombo}"
                                                              SelectionChanged="ElyFlowCombo_Changed">
                                                        <ComboBoxItem Tag="nvidia-fruc" Content="NVIDIA Optical Flow FRUC"/>
                                                        <ComboBoxItem Tag="mpv-pacing" Content="mpv pacing / display-resample"/>
                                                    </ComboBox>
                                                </Grid>

                                                <CheckBox x:Name="ElyFlowRtxVsrSwitch" Margin="0,12,0,2"
                                                          Style="{StaticResource Switch}"
                                                          Content="RTX Video Super Resolution before FRUC"
                                                          ToolTip="NVIDIA AI upscale on D3D11, followed by FRUC interpolation at output resolution."
                                                          Click="ElyFlowSetting_Changed"/>

                                                <Grid Margin="0,10,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="260"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="ElyFlowTargetLabel" Text="Target FPS (mpv pacing)" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <ComboBox x:Name="ElyFlowTargetCombo" Grid.Column="1" Height="40"
                                                              Style="{StaticResource FieldCombo}"
                                                              SelectionChanged="ElyFlowCombo_Changed">
                                                        <ComboBoxItem Tag="30" Content="30 fps"/>
                                                        <ComboBoxItem Tag="60000/1001" Content="59.94 fps"/>
                                                        <ComboBoxItem Tag="60" Content="60 fps"/>
                                                        <ComboBoxItem Tag="120" Content="120 fps"/>
                                                        <ComboBoxItem Tag="144" Content="144 fps"/>
                                                        <ComboBoxItem Tag="165" Content="165 fps"/>
                                                        <ComboBoxItem Tag="240" Content="240 fps"/>
                                                        <ComboBoxItem Tag="360" Content="360 fps"/>
                                                    </ComboBox>
                                                </Grid>

                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="58"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Live post-processing buffer" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <Slider x:Name="ElyFlowLiveBufferSlider" Grid.Column="1"
                                                            Minimum="0.5" Maximum="5" ValueChanged="ElyFlowSlider_Changed"
                                                            Style="{StaticResource VolumeSlider}"/>
                                                    <TextBlock x:Name="ElyFlowLiveBufferValue" Grid.Column="2" Text="5.0s"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource MutedBrush}"/>
                                                </Grid>

                                                <Border Margin="0,18,0,0" Padding="14,12" CornerRadius="8"
                                                        Background="#22000000" BorderBrush="{DynamicResource CardStroke}" BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="NVIDIA FRUC status" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextBrush}"/>
                                                        <TextBlock x:Name="ElyFlowStatusText" Margin="0,6,0,0"
                                                                   TextWrapping="Wrap" FontSize="12"
                                                                   Foreground="{DynamicResource FaintBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel x:Name="SettingsSystemPanel" Visibility="Collapsed">

                                            <TextBlock Text="ELYSMART" Margin="0,26,0,6" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource AccentBBrush}"/>
                                            <TextBlock Text="ElyCast's built-in performance engineer. Measurements, detections, and estimates remain identified separately."
                                                       Foreground="{DynamicResource FaintBrush}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Primary use" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                                <ComboBox x:Name="ElySmartProfileCombo" Grid.Column="1" Height="40" Style="{StaticResource FieldCombo}">
                                                    <ComboBoxItem Tag="Iptv" Content="IPTV: stability"/><ComboBoxItem Tag="Movies" Content="Movies: quality"/>
                                                    <ComboBoxItem Tag="Series" Content="Series: balance"/><ComboBoxItem Tag="Anime" Content="Anime: Anime4K"/>
                                                    <ComboBoxItem Tag="Audio" Content="Audio: visualizer"/><ComboBoxItem Tag="Mixed" Content="Mixed"/>
                                                </ComboBox>
                                            </Grid>
                                            <CheckBox x:Name="ElySmartNotificationsSwitch" Style="{StaticResource Switch}" Margin="0,12,0,0"
                                                      Content="Show ELYSMART notifications" Click="ElySmartNotificationsSwitch_Click"/>
                                            <CheckBox x:Name="ElySmartAutoSwitch" Style="{StaticResource Switch}" Margin="0,12,0,0"
                                                      Content="Automatically optimize decorative effects only" Click="ElySmartAutoSwitch_Click"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                                <Button x:Name="ElySmartRunButton" Content="Optimize ElyCast automatically" Style="{StaticResource PrimaryButton}" Width="280" Height="44" Click="ElySmartRun_Click"/>
                                                <Button x:Name="ElySmartCancelButton" Content="Cancel" Style="{StaticResource GhostButton}" Width="100" Height="44" Margin="10,0,0,0" Visibility="Collapsed" Click="ElySmartCancel_Click"/>
                                                <Button x:Name="ElySmartApplyButton" Content="Apply" Style="{StaticResource GhostButton}" Width="110" Height="44" Margin="10,0,0,0" Visibility="Collapsed" Click="ElySmartApply_Click"/>
                                                <Button x:Name="ElySmartExportButton" Content="Export" Style="{StaticResource GhostButton}" Width="110" Height="44" Margin="10,0,0,0" Click="ElySmartExport_Click"/>
                                            </StackPanel>
                                            <ProgressBar x:Name="ElySmartProgress" Height="7" Margin="0,14,0,0" Minimum="0" Maximum="100" Visibility="Collapsed"/>
                                            <TextBlock x:Name="ElySmartStatusText" Margin="0,10,0,0" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Text="No analysis has been run."/>
                                            <Border Margin="0,12,0,8" Padding="14" CornerRadius="8" Background="#22000000" BorderBrush="{DynamicResource CardStroke}" BorderThickness="1">
                                                <TextBlock x:Name="ElySmartReportText" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource FaintBrush}" TextWrapping="Wrap" Text="The detailed report will appear here."/>
                                            </Border>
                                            <TextBlock Text="REAL-TIME DIAGNOSTICS: 5 MINUTES" Margin="0,18,0,7" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                            <local:ElySmartDiagnosticSurface x:Name="ElySmartDiagnosticGraph" Height="180"/>
                                            <TextBlock x:Name="ElySmartLiveMetricsText" Margin="0,7,0,0" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource FaintBrush}" Text="Waiting for the first measurements..."/>

                                             <TextBlock Text="STARTUP" Margin="0,26,0,6" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                            <CheckBox x:Name="ZapSwitch" Style="{StaticResource Switch}"
                                                      Content="Zap with the ↑ ↓ arrow keys" Click="Setting_Changed"/>
                                            <CheckBox x:Name="ConfirmExitSwitch" Style="{StaticResource Switch}"
                                                      Content="Confirm before exiting" Click="Setting_Changed"/>
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="180"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Console duration at startup (s)" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextBrush}"/>
                                                <Slider x:Name="BootSlider" Grid.Column="1" Minimum="2" Maximum="12"
                                                        Style="{StaticResource VolumeSlider}" ValueChanged="SliderSetting_Changed"/>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                                                <Button Content="Open data folder" Style="{StaticResource GhostButton}"
                                                        Height="42" Width="240" Click="OpenDataFolder_Click"/>
                                                <Button Content="Reset" Style="{StaticResource GhostButton}"
                                                        Height="42" Width="130" Margin="10,0,0,0" Click="ResetSettings_Click"/>
                                            </StackPanel>

                                            <TextBlock Text="COMING SOON" Margin="0,28,0,8" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                            <TextBlock Foreground="{DynamicResource FaintBrush}" FontSize="12" TextWrapping="Wrap"
                                                       Text="Stream recording and screenshot   • Picture-in-Picture and taskbar minimization   • Multi-stream mosaic   • PIN parental controls   • Local logo cache   • Shortcut help overlay (?)"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                                </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
