<Window x:Class="Elysium_Cast_IPTV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Elysium_Cast_IPTV"
        Title="ElyCast" Icon="Assets/ElyCast.ico"
        Height="760" Width="1240" MinHeight="600" MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{DynamicResource AppBackground}"
        FontFamily="{StaticResource UiFont}"
        Foreground="{DynamicResource TextBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="6"
                      CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TitleRow" Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ============ TITLE BAR ============ -->
            <Grid x:Name="TitleBar" Grid.Row="0" Background="Transparent">
                <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                    <Border Width="22" Height="22" CornerRadius="7" Background="{DynamicResource AccentBrush}">
                        <Path Data="M 5,3 L 12,8 L 5,13 Z" Fill="White" Stretch="Uniform"
                              Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13"
                               FontWeight="Bold" Foreground="{DynamicResource TextBrush}">
                        ELY<Run Foreground="{DynamicResource AccentBBrush}">CAST</Run>
                    </TextBlock>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ConsoleBtn" Style="{StaticResource CaptionButton}" Width="54"
                            Click="Console_Click" ToolTip="Afficher / masquer la console de debug">
                        <Path Data="M 1,1 L 11,1 L 11,9 L 1,9 Z M 3,4 L 5,5.5 L 3,7 M 6,7 L 9,7"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.1" Stretch="Uniform" Width="15" Height="13"/>
                    </Button>
                    <Button x:Name="MinBtn" Style="{StaticResource CaptionButton}" Click="Min_Click">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1" Data="M 0,5 L 10,5"/>
                    </Button>
                    <Button x:Name="MaxBtn" Style="{StaticResource CaptionButton}" Click="Max_Click">
                        <Rectangle Width="9" Height="9"
                                   Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   StrokeThickness="1"/>
                    </Button>
                    <Button x:Name="CloseBtn" Style="{StaticResource CaptionButton}" Click="Close_Click">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.2" Data="M 0,0 L 10,10 M 10,0 L 0,10"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ============ CONTENT ============ -->
            <Grid Grid.Row="1">

                <!-- ====== LOGIN VIEW ====== -->
                <Grid x:Name="LoginView">
                    <Border Width="470" MaxHeight="640" VerticalAlignment="Center" HorizontalAlignment="Center"
                            CornerRadius="22" Background="{StaticResource CardBrush}"
                            BorderBrush="{DynamicResource CardStroke}" BorderThickness="1"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="56" ShadowDepth="0" Opacity="0.6" Color="{DynamicResource GlowColor}"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="LoginCardT" Y="24"/>
                        </Border.RenderTransform>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="36,32,36,32">
                            <StackPanel>
                                <TextBlock x:Name="WelcomeTitle" Text="Bienvenue 👋" FontSize="26" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Margin="0,6,0,0" FontSize="13" TextWrapping="Wrap"
                                           Foreground="{DynamicResource MutedBrush}"
                                           Text="Connecte-toi via Xtream Codes ou une playlist M3U pour commencer."/>

                                <StackPanel x:Name="ProfilesSection" Visibility="Collapsed">
                                    <TextBlock Text="PROFILS ENREGISTRÉS" Margin="0,24,0,10" FontSize="11"
                                               FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                    <ItemsControl x:Name="ProfilesItems">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,8,8">
                                                    <Button Click="LoadProfile_Click" Tag="{Binding}"
                                                            Cursor="Hand" HorizontalContentAlignment="Left">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="bd" CornerRadius="12" Padding="10,8"
                                                                        Background="{StaticResource FieldBrush}"
                                                                        BorderBrush="{DynamicResource FieldStroke}"
                                                                        BorderThickness="1">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Border Width="32" Height="32" CornerRadius="9"
                                                                                Background="{DynamicResource AccentBrush}">
                                                                            <TextBlock Text="{Binding Initial}"
                                                                                FontWeight="Bold" Foreground="White"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <StackPanel Margin="10,0,8,0" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                                                FontWeight="SemiBold"
                                                                                Foreground="{DynamicResource TextBrush}"/>
                                                                            <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                                                                Foreground="{DynamicResource MutedBrush}"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="bd" Property="BorderBrush"
                                                                                Value="{DynamicResource AccentABrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    <Button Click="DeleteProfile_Click" Tag="{Binding}"
                                                            Width="18" Height="18" Cursor="Hand"
                                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                                            Margin="0,-6,-6,0" ToolTip="Supprimer ce profil">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="b" CornerRadius="9" Background="{DynamicResource AccentDeepBrush}">
                                                                    <Path Data="M 0,0 L 6,6 M 6,0 L 0,6" Stroke="{DynamicResource AccentSoftBrush}"
                                                                          StrokeThickness="1.2" Stretch="Uniform"
                                                                          Width="7" Height="7"
                                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentABrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <Border Margin="0,22,0,0" CornerRadius="12" Background="{StaticResource FieldBrush}"
                                        BorderBrush="{DynamicResource FieldStroke}" BorderThickness="1" Padding="4" Height="44">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="TabHighlight" Grid.Column="0" CornerRadius="9"
                                                Background="{DynamicResource AccentBrush}"/>
                                        <Button x:Name="XtreamTabBtn" Grid.Column="0" Content="Xtream Codes"
                                                Background="Transparent" Foreground="White" FontWeight="SemiBold"
                                                BorderThickness="0" Cursor="Hand" Click="XtreamTab_Click"/>
                                        <Button x:Name="M3uTabBtn" Grid.Column="1" Content="Playlist M3U"
                                                Background="Transparent" Foreground="{DynamicResource MutedBrush}"
                                                FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="M3uTab_Click"/>
                                    </Grid>
                                </Border>

                                <StackPanel x:Name="XtreamPanel">
                                    <TextBlock Text="URL DU SERVEUR" Margin="0,20,0,8" FontSize="11"
                                               FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                    <TextBox x:Name="UrlBox" Style="{StaticResource FieldBox}" Tag="http://exemple.com:8080"/>
                                    <TextBlock Text="NOM D'UTILISATEUR" Margin="0,16,0,8" FontSize="11"
                                               FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                    <TextBox x:Name="UserBox" Style="{StaticResource FieldBox}" Tag="utilisateur"/>
                                    <TextBlock Text="MOT DE PASSE" Margin="0,16,0,8" FontSize="11"
                                               FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                    <Grid>
                                        <PasswordBox x:Name="PassBox" Foreground="{DynamicResource TextBrush}"
                                                     CaretBrush="{DynamicResource AccentBBrush}" FontSize="14" Height="48"
                                                     VerticalContentAlignment="Center" PasswordChanged="PassBox_PasswordChanged">
                                            <PasswordBox.Template>
                                                <ControlTemplate TargetType="PasswordBox">
                                                    <Border CornerRadius="12" Background="{StaticResource FieldBrush}"
                                                            BorderBrush="{DynamicResource FieldStroke}" BorderThickness="1.5"
                                                            Padding="16,0">
                                                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </PasswordBox.Template>
                                        </PasswordBox>
                                        <TextBlock x:Name="PassPlaceholder" Text="mot de passe" Margin="17,0,0,0"
                                                   VerticalAlignment="Center" IsHitTestVisible="False"
                                                   Foreground="{DynamicResource FaintBrush}"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel x:Name="M3uPanel" Visibility="Collapsed">
                                    <TextBlock Text="FICHIER OU URL M3U" Margin="0,20,0,8" FontSize="11"
                                               FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="M3uPathBox" Style="{StaticResource FieldBox}"
                                                 Tag="C:\playlist.m3u ou http://…/list.m3u"/>
                                        <Button Grid.Column="1" Content="Parcourir…" Style="{StaticResource GhostButton}"
                                                Height="48" Width="110" Margin="8,0,0,0" Click="Browse_Click"/>
                                    </Grid>
                                </StackPanel>

                                <CheckBox x:Name="SaveProfileCheck" Margin="2,18,0,0" Foreground="{DynamicResource MutedBrush}"
                                          Content="Enregistrer ce profil" Checked="SaveProfile_Toggle" Unchecked="SaveProfile_Toggle"/>
                                <StackPanel x:Name="ProfileNamePanel" Visibility="Collapsed">
                                    <TextBox x:Name="ProfileNameBox" Style="{StaticResource FieldBox}" Height="42"
                                             Margin="0,10,0,0" Tag="Nom du profil"/>
                                </StackPanel>

                                <Button x:Name="ConnectBtn" Style="{StaticResource PrimaryButton}"
                                        Margin="0,24,0,0" Click="Connect_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Grid Width="18" Height="18" Margin="0,0,8,0">
                                            <Ellipse x:Name="LoginSpinner" Width="16" Height="16" Stroke="White"
                                                     StrokeThickness="2" StrokeDashArray="3 2" Visibility="Collapsed"
                                                     RenderTransformOrigin="0.5,0.5">
                                                <Ellipse.RenderTransform><RotateTransform/></Ellipse.RenderTransform>
                                            </Ellipse>
                                            <Path x:Name="LoginIcon" Data="M 0,4 L 8,4 M 5,1 L 8,4 L 5,7" Stroke="White"
                                                  StrokeThickness="1.6" Stretch="Uniform" Width="14" Height="14"/>
                                        </Grid>
                                        <TextBlock x:Name="ConnectLabel" Text="Se connecter"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock x:Name="StatusText" Margin="0,14,0,0" FontSize="12" TextWrapping="Wrap"
                                           HorizontalAlignment="Center" TextAlignment="Center" Foreground="#FFFF8A8A"/>

                                <!-- No IPTV account needed: jump straight into the local library. -->
                                <Button Style="{StaticResource GhostButton}" Margin="0,16,0,0" Height="44"
                                        Click="LocalOnly_Click"
                                        ToolTip="Utiliser ElyCast sans compte IPTV : vidéos et musique locales">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💻" FontSize="13" Margin="0,0,8,0"/>
                                        <TextBlock Text="Continuer sans IPTV — bibliothèque locale"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- ====== PLAYER VIEW ====== -->
                <Grid x:Name="PlayerView" Visibility="Collapsed" Opacity="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="NavColumn" Width="76"/>
                        <ColumnDefinition x:Name="SidebarColumn" Width="330"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- NAV RAIL -->
                    <Border x:Name="NavRail" Grid.Column="0" Margin="14,0,0,14" CornerRadius="18"
                            Background="{StaticResource CardBrush}" BorderBrush="{DynamicResource CardStroke}"
                            BorderThickness="1">
                        <Grid Margin="0,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <RadioButton x:Name="NavLive" Style="{StaticResource NavRadio}" IsChecked="True"
                                             GroupName="nav" Checked="Nav_Changed" Tag="Live">
                                    <StackPanel>
                                        <Path Data="M2,3 H18 V14 H2 Z M7,17 H13" Stretch="Uniform" Width="22" Height="20"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.4"/>
                                        <TextBlock Text="Live" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="NavMovies" Style="{StaticResource NavRadio}" GroupName="nav" Checked="Nav_Changed" Tag="Movies">
                                    <StackPanel>
                                        <Path Data="M2,4 H18 V16 H2 Z M2,8 H18 M5,4 V8 M9,4 V8 M13,4 V8" Stretch="Uniform"
                                              Width="22" Height="20"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.4"/>
                                        <TextBlock Text="Films" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="NavSeries" Style="{StaticResource NavRadio}" GroupName="nav" Checked="Nav_Changed" Tag="Series">
                                    <StackPanel>
                                        <Path Data="M4,6 H16 V15 H4 Z M6,3 H14 M4,9 H16" Stretch="Uniform" Width="22" Height="20"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.4"/>
                                        <TextBlock Text="Séries" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="NavLocalAudio" Style="{StaticResource NavRadio}" GroupName="nav" Checked="Nav_Changed" Tag="LocalAudio">
                                    <StackPanel>
                                        <Path Data="M14,2 V13 A3,3 0 1 1 12,10 V5 L6,7 V15 A3,3 0 1 1 4,12 V5 Z" Stretch="Uniform" Width="22" Height="20"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.4"/>
                                        <TextBlock Text="Audio" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="NavLocalVideo" Style="{StaticResource NavRadio}" GroupName="nav" Checked="Nav_Changed" Tag="LocalVideo">
                                    <StackPanel>
                                        <Path Data="M2,4 H18 V16 H2 Z M8,7 L14,10 L8,13 Z" Stretch="Uniform" Width="22" Height="20"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="1.4"/>
                                        <TextBlock Text="Vidéo" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="NavFav" Style="{StaticResource NavRadio}" GroupName="nav" Checked="Nav_Changed" Tag="Fav">
                                    <StackPanel>
                                        <Path Data="M10,1 L12.6,6.7 L19,7.3 L14,11.6 L15.6,18 L10,14.5 L4.4,18 L6,11.6 L1,7.3 L7.4,6.7 Z"
                                              Stretch="Uniform" Width="22" Height="20"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.3"/>
                                        <TextBlock Text="Favoris" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>

                            <StackPanel Grid.Row="2">
                                <RadioButton x:Name="NavSettings" Style="{StaticResource NavRadio}" GroupName="nav"
                                             Checked="Nav_Changed" Tag="Settings">
                                    <StackPanel>
                                        <Path Data="M2,5 H16 M2,10 H16 M2,15 H16 M6,3 H8 V7 H6 Z M11,8 H13 V12 H11 Z M5,13 H7 V17 H5 Z"
                                              Stretch="Uniform" Width="22" Height="20"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                              StrokeThickness="1.3"/>
                                        <TextBlock Text="Réglages" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>
                                <Button Style="{StaticResource NavButton}" Click="Disconnect_Click"
                                        Foreground="{DynamicResource MutedBrush}">
                                    <StackPanel>
                                        <Path Data="M8,1 L3,1 L3,17 L8,17 M6,9 H15 M11,5 L15,9 L11,13" Stretch="Uniform"
                                              Width="22" Height="20" Stroke="{DynamicResource MutedBrush}" StrokeThickness="1.3"/>
                                        <TextBlock Text="Quitter" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                   Foreground="{DynamicResource MutedBrush}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- SIDEBAR -->
                    <Border x:Name="Sidebar" Grid.Column="1" Margin="10,0,7,14" CornerRadius="18"
                            Background="{StaticResource CardBrush}" BorderBrush="{DynamicResource CardStroke}"
                            BorderThickness="1">
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock x:Name="SectionTitle" Text="Chaînes" FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <Border Margin="10,0,0,0" Padding="8,2" CornerRadius="9" VerticalAlignment="Center"
                                        Background="#3A8B5CF6">
                                    <TextBlock x:Name="CountText" Text="0" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#FFCBB8FF"/>
                                </Border>
                            </StackPanel>

                            <Button x:Name="ResumeButton" Grid.Row="1" Margin="0,12,0,0" Visibility="Collapsed"
                                    Style="{StaticResource GhostButton}" Height="44" Click="Resume_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M3,8 A5,5 0 1 1 8,13 M3,8 L1,6 M3,8 L5,6" Stretch="Uniform" Width="15" Height="15"
                                          Stroke="{DynamicResource AccentBBrush}" StrokeThickness="1.4" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="ResumeText" Text="Reprendre" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                                </StackPanel>
                            </Button>

                            <StackPanel x:Name="LocalActionsPanel" Grid.Row="1" Margin="0,12,0,0"
                                        Visibility="Collapsed">
                                <Button x:Name="LocalImportButton" Content="Importer un dossier" Style="{StaticResource GhostButton}"
                                        Height="40" Click="ImportLocalFolder_Click"/>
                                <StackPanel x:Name="AudioLibraryActions">
                                    <ComboBox x:Name="AudioBrowseCombo" Margin="0,8,0,0" Style="{StaticResource FieldCombo}"
                                              SelectionChanged="AudioBrowse_Changed">
                                        <ComboBoxItem Content="Albums" Tag="albums"/>
                                        <ComboBoxItem Content="Artistes" Tag="artists"/>
                                        <ComboBoxItem Content="Genres" Tag="genres"/>
                                        <ComboBoxItem Content="Playlists" Tag="playlists"/>
                                        <ComboBoxItem Content="Tous les titres" Tag="tracks"/>
                                    </ComboBox>
                                    <Grid x:Name="PlaylistCreateRow" Margin="0,8,0,0" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBox x:Name="PlaylistNameBox" Style="{StaticResource SearchBox}" Tag="Nouvelle playlist"
                                                 KeyDown="PlaylistNameBox_KeyDown"/>
                                        <Button Grid.Column="1" Content="+" Width="38" Margin="6,0,0,0" Style="{StaticResource GhostButton}"
                                                ToolTip="Créer la playlist" Click="CreatePlaylist_Click"/>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ToggleButton x:Name="ShuffleToggle" Content="Aléatoire" Margin="0,0,6,0"
                                                      Style="{StaticResource AudioActionToggle}" Checked="Shuffle_Checked" Unchecked="Shuffle_Checked"/>
                                        <ToggleButton x:Name="RepeatToggle" Grid.Column="1" Content="Répéter"
                                                      Style="{StaticResource AudioActionToggle}" Checked="Repeat_Checked" Unchecked="Repeat_Checked"/>
                                        <TextBlock x:Name="QueueCountText" Grid.Column="2" Text="File : 0" FontSize="11" Margin="10,0,6,0"
                                                   Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        <Button Grid.Column="3" Content="Vider" Height="28" FontSize="11" Padding="8,0"
                                                Style="{StaticResource GhostButton}" ToolTip="Vider la file d’attente" Click="ClearQueue_Click"/>
                                    </Grid>
                                    <Button x:Name="ResetAudioLibraryButton" Content="Réinitialiser la bibliothèque" Height="32"
                                            FontSize="11" Margin="0,8,0,0" Style="{StaticResource GhostButton}"
                                            ToolTip="Retirer tous les titres importés (les fichiers ne sont pas supprimés du disque)"
                                            Click="ResetAudioLibrary_Click"/>
                                </StackPanel>
                                <StackPanel x:Name="VideoLibraryActions" Visibility="Collapsed"/>
                                <Button x:Name="RemoveLocalButton" Content="Retirer de la liste" Style="{StaticResource GhostButton}"
                                        Height="36" Margin="0,8,0,0" Click="RemoveLocalFile_Click"/>
                            </StackPanel>

                            <ComboBox x:Name="CategoryCombo" Grid.Row="2" Margin="0,12,0,0"
                                      Style="{StaticResource FieldCombo}" SelectionChanged="Category_Changed"/>

                            <TextBox x:Name="SearchBox" Grid.Row="3" Margin="0,10,0,10" Style="{StaticResource SearchBox}"
                                     Tag="Rechercher…" TextChanged="SearchBox_TextChanged"/>

                            <ListBox x:Name="ItemList" Grid.Row="4" Style="{StaticResource ChannelListBox}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                                     PreviewMouseRightButtonDown="ItemList_RightClick"
                                     MouseDoubleClick="ItemList_DoubleClick">
                                <ListBox.ContextMenu>
                                    <ContextMenu Opened="LocalItemMenu_Opened">
                                        <MenuItem Header="Lire maintenant" Click="PlayNow_Click"/>
                                        <Separator/>
                                        <MenuItem x:Name="ContextPlayNext" Header="Lire juste après" Click="PlayNext_Click"/>
                                        <MenuItem x:Name="ContextAddQueue" Header="Ajouter à la file d’attente" Click="AddToQueue_Click"/>
                                        <MenuItem x:Name="ContextAddPlaylist" Header="Ajouter à une playlist"/>
                                        <MenuItem x:Name="ContextEditMeta" Header="Modifier les métadonnées…" Click="EditMetadata_Click"/>
                                        <Separator/>
                                        <MenuItem x:Name="ContextRemoveLibrary" Header="Retirer de la bibliothèque" Click="RemoveTrack_Click"/>
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="34" Height="34">
                                                <Border CornerRadius="9" Background="#33000000">
                                                    <TextBlock Text="{Binding Initial}" FontWeight="Bold" FontSize="14"
                                                               Foreground="{DynamicResource AccentSoftBrush}" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <Image Source="{Binding Icon}" Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Clip>
                                                        <RectangleGeometry Rect="0,0,34,34" RadiusX="9" RadiusY="9"/>
                                                    </Image.Clip>
                                                </Image>
                                                <Image Source="{Binding Cover}" Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Clip>
                                                        <RectangleGeometry Rect="0,0,34,34" RadiusX="9" RadiusY="9"/>
                                                    </Image.Clip>
                                                </Image>
                                            </Grid>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                                           FontSize="13" Foreground="{DynamicResource TextBrush}"/>
                                                <TextBlock Text="{Binding CategoryName}" TextTrimming="CharacterEllipsis"
                                                           FontSize="10" Foreground="{DynamicResource FaintBrush}"/>
                                            </StackPanel>
                                            <ToggleButton Grid.Column="2" Style="{StaticResource StarToggle}"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{Binding IsFavorite, Mode=TwoWay}"
                                                          Checked="Fav_Toggle" Unchecked="Fav_Toggle"
                                                          ToolTip="Favori"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Grouped music browsing (albums / artists / genres / playlists).
                                 Shown instead of ItemList in the local-audio section; a click
                                 opens the detail panel over the player. -->
                            <ListBox x:Name="MusicGroupList" Grid.Row="4" Style="{StaticResource ChannelListBox}"
                                     Visibility="Collapsed"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                                     PreviewMouseRightButtonDown="ItemList_RightClick"
                                     PreviewMouseLeftButtonUp="MusicGroupList_Click">
                                <ListBox.ContextMenu>
                                    <ContextMenu Opened="MusicGroupMenu_Opened">
                                        <MenuItem Header="Tout lire" Click="GroupPlay_Click"/>
                                        <MenuItem Header="Lecture aléatoire" Click="GroupShuffle_Click"/>
                                        <MenuItem Header="Ajouter à la file d’attente" Click="GroupQueue_Click"/>
                                        <Separator/>
                                        <MenuItem x:Name="ContextRemoveMusicGroup" Header="Retirer de la bibliothèque" Click="RemoveMusicGroup_Click"/>
                                        <Separator x:Name="ContextPlaylistSeparator"/>
                                        <MenuItem x:Name="ContextDeletePlaylist" Header="Supprimer la playlist" Click="DeletePlaylist_Click"/>
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="46" Height="46">
                                                <Border CornerRadius="10" Background="#33000000">
                                                    <TextBlock Text="{Binding Initial}" FontWeight="Bold" FontSize="17"
                                                               Foreground="{DynamicResource AccentSoftBrush}" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <Image Source="{Binding Cover}" Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Clip>
                                                        <RectangleGeometry Rect="0,0,46,46" RadiusX="10" RadiusY="10"/>
                                                    </Image.Clip>
                                                </Image>
                                            </Grid>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                                           FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                                <TextBlock Text="{Binding Subtitle}" TextTrimming="CharacterEllipsis"
                                                           FontSize="10" Foreground="{DynamicResource FaintBrush}"/>
                                            </StackPanel>
                                            <Border Grid.Column="2" Padding="7,2" CornerRadius="8" VerticalAlignment="Center"
                                                    Background="#26FFFFFF">
                                                <TextBlock Text="{Binding CountLabel}" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MutedBrush}"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- MAIN AREA -->
                    <Grid x:Name="VideoArea" Grid.Column="2" Margin="7,0,14,14">
                        <Border x:Name="VideoStage" CornerRadius="18" Background="#FF030305"
                                BorderBrush="{DynamicResource CardStroke}" BorderThickness="1" ClipToBounds="True"
                                MouseMove="Stage_MouseMove" MouseLeave="Stage_MouseLeave">
                            <Grid>
                                <ContentControl x:Name="VideoHost"/>

                                <!-- ===== AIRSPACE OVERLAY =====
                                     mpv renders into a native child HWND (VideoHost) which always sits
                                     on top of in-window WPF content. To draw the OSD/menus/overlays
                                     over the video, OverlayRoot is reparented at runtime into a
                                     transparent borderless Window owned by this one (code-behind,
                                     EnsureOverlayWindow). A Popup cannot be used here: WPF clamps
                                     popups to the monitor edges, so it detached from the window
                                     whenever it was dragged partially off-screen. This collapsed
                                     mount only declares the content. -->
                                <Border x:Name="OverlayMount" Visibility="Collapsed">
                                <Grid x:Name="OverlayRoot" Background="Transparent"
                                      MouseMove="Stage_MouseMove" MouseLeave="Stage_MouseLeave"
                                      PreviewMouseLeftButtonUp="OverlayRoot_MouseLeftButtonUp">

                                <!-- idle / loading -->
                                <Grid x:Name="VideoOverlay" Background="#FF060309">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Grid Width="64" Height="64">
                                            <Ellipse Width="64" Height="64" Stroke="#22FFFFFF" StrokeThickness="3"/>
                                            <Ellipse x:Name="BigSpinner" Width="64" Height="64" Stroke="{DynamicResource AccentBBrush}"
                                                     StrokeThickness="3" StrokeDashArray="20 60" Visibility="Collapsed"
                                                     RenderTransformOrigin="0.5,0.5">
                                                <Ellipse.RenderTransform><RotateTransform/></Ellipse.RenderTransform>
                                            </Ellipse>
                                            <Path x:Name="IdlePlay" Data="M 5,3 L 12,8 L 5,13 Z" Fill="#55FFFFFF"
                                                  Stretch="Uniform" Width="22" Height="22"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock x:Name="OverlayText" Margin="0,18,0,0" FontSize="14"
                                                   HorizontalAlignment="Center" Foreground="{DynamicResource MutedBrush}"
                                                   Text="Sélectionne une chaîne pour lancer la lecture"/>
                                    </StackPanel>
                                </Grid>

                                <Grid x:Name="AudioVisualizerLayer" Visibility="Collapsed" ClipToBounds="True">
                                    <!-- Le fond reste immobile : seule la grille de contenu est secouée,
                                         sinon la translation révélait le bord de la couche (lignes claires). -->
                                    <Grid.Background>
                                        <RadialGradientBrush Center="0.5,0.45" GradientOrigin="0.5,0.45" RadiusX="0.82" RadiusY="0.82">
                                            <GradientStop Color="#FF220B18" Offset="0"/>
                                            <GradientStop Color="#FF08070D" Offset="0.58"/>
                                            <GradientStop Color="#FF000000" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Grid.Background>

                                    <!-- Optional artwork/photo background. Overscan prevents the blur and the
                                         subtle pan/zoom animation from exposing the player edges. -->
                                    <Image x:Name="AudioBackgroundImage" Stretch="UniformToFill" Opacity="0"
                                           Margin="-54" IsHitTestVisible="False"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           RenderTransformOrigin="0.5,0.5">
                                        <!-- Cache the expensive full-screen Gaussian blur. Slow movement then
                                             transforms one GPU bitmap instead of recomputing the effect per frame. -->
                                        <Image.CacheMode><BitmapCache RenderAtScale="0.45" EnableClearType="False" SnapsToDevicePixels="False"/></Image.CacheMode>
                                        <Image.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform x:Name="AudioBackgroundScale" ScaleX="1.04" ScaleY="1.04"/>
                                                <TranslateTransform x:Name="AudioBackgroundTranslate"/>
                                            </TransformGroup>
                                        </Image.RenderTransform>
                                        <Image.Effect><BlurEffect x:Name="AudioBackgroundBlurEffect" Radius="45.6" KernelType="Gaussian"/></Image.Effect>
                                    </Image>
                                    <Border x:Name="AudioBackgroundDimmer" Background="#D9000000" IsHitTestVisible="False"/>

                                    <Grid>
                                        <Grid.RenderTransform>
                                            <TranslateTransform x:Name="AudioVisualizerShake"/>
                                        </Grid.RenderTransform>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <!-- Passe à * quand le fichier embarque des métadonnées. -->
                                            <ColumnDefinition x:Name="AudioMetaColumn" Width="0"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- ===== Visualizer (adaptatif) ===== -->
                                        <Grid Grid.Column="0">
                                            <!-- Barres FFT + particules + ondes de choc : une seule passe
                                                 OnRender sans allocation, redessinée à la cadence de l'écran.
                                                 La surface se met elle-même à l'échelle de sa cellule. -->
                                            <local:AudioVisualizerSurface x:Name="AudioSurface"/>

                                            <!-- Les anneaux/disque suivent la même échelle via le Viewbox
                                                 (Uniform, plafonné à la taille native de 560). -->
                                            <Viewbox Stretch="Uniform" StretchDirection="DownOnly" Margin="24"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Grid Width="560" Height="560" RenderTransformOrigin="0.5,0.5">
                                                    <Grid.RenderTransform>
                                                        <ScaleTransform x:Name="AudioVisualizerScale" ScaleX="1" ScaleY="1"/>
                                                    </Grid.RenderTransform>
                                                    <Ellipse Width="516" Height="516" Stroke="#22FFFFFF" StrokeThickness="1.5"/>
                                                    <Ellipse x:Name="AudioOuterRing" Width="472" Height="472" Stroke="#AAFFFFFF"
                                                             StrokeThickness="2" StrokeDashArray="4 11" RenderTransformOrigin="0.5,0.5"
                                                             CacheMode="BitmapCache">
                                                        <Ellipse.RenderTransform>
                                                            <RotateTransform x:Name="AudioOuterRingRotate"/>
                                                        </Ellipse.RenderTransform>
                                                    </Ellipse>
                                                    <Ellipse x:Name="AudioGlowRing" Width="388" Height="388" Stroke="#FFFFC46B"
                                                             StrokeThickness="4" Opacity="0.7" CacheMode="BitmapCache">
                                                        <Ellipse.Effect>
                                                            <BlurEffect Radius="15"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <!-- Disque central : l'image remplit tout le cercle (UniformToFill),
                                                         pulse sur les basses via AudioCenterScale. BitmapCache : l'ombre
                                                         portée n'est rasterisée qu'une fois, la pulsation ne coûte rien. -->
                                                    <Ellipse x:Name="AudioCenterDisc" Width="336" Height="336"
                                                             Stroke="#44FFFFFF" StrokeThickness="2"
                                                             RenderTransformOrigin="0.5,0.5" CacheMode="BitmapCache">
                                                        <Ellipse.Fill>
                                                            <ImageBrush x:Name="AudioDiscBrush" ImageSource="/Assets/FleweastAudio.png"
                                                                        Stretch="UniformToFill"
                                                                        RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Ellipse.Fill>
                                                        <Ellipse.RenderTransform>
                                                            <ScaleTransform x:Name="AudioCenterScale" ScaleX="1" ScaleY="1"/>
                                                        </Ellipse.RenderTransform>
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="46" ShadowDepth="0" Opacity="0.9" Color="#FF000000"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                            </Viewbox>

                                            <StackPanel x:Name="AudioTitleBlock" HorizontalAlignment="Center"
                                                        VerticalAlignment="Bottom" Margin="24,0,24,28">
                                                <TextBlock x:Name="AudioVisualizerTitle" Text="Elycast Audio" FontSize="18"
                                                           FontWeight="Bold" Foreground="White" TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="620"/>
                                                <TextBlock Text="ELYCAST AUDIO" FontSize="11" Margin="0,5,0,0"
                                                           Foreground="#AAFFFFFF" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- ===== Métadonnées (pochette + titre/artiste/album) ===== -->
                                        <Viewbox x:Name="AudioMetaPanel" Grid.Column="1" Visibility="Collapsed"
                                                 Stretch="Uniform" StretchDirection="DownOnly"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Margin="8,32,40,32">
                                            <StackPanel Width="440">
                                                <Border Width="400" Height="400" CornerRadius="24"
                                                        HorizontalAlignment="Center" CacheMode="BitmapCache">
                                                    <Border.Background>
                                                        <ImageBrush x:Name="AudioCoverBrush" Stretch="UniformToFill"
                                                                    RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Border.Background>
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="42" ShadowDepth="0" Opacity="0.85" Color="#FF000000"/>
                                                    </Border.Effect>
                                                </Border>
                                                <TextBlock x:Name="AudioMetaTitle" Margin="0,26,0,0" FontSize="26"
                                                           FontWeight="Bold" Foreground="White" TextAlignment="Center"
                                                           TextWrapping="Wrap" MaxHeight="96"/>
                                                <TextBlock x:Name="AudioMetaArtist" Margin="0,8,0,0" FontSize="16"
                                                           Foreground="#FFCBB8FF" TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock x:Name="AudioMetaAlbum" Margin="0,4,0,0" FontSize="12"
                                                           Foreground="#AAFFFFFF" TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Viewbox>
                                    </Grid>
                                </Grid>

                                <!-- stats -->
                                <Border x:Name="StatsOverlay" Visibility="Collapsed" HorizontalAlignment="Left"
                                        VerticalAlignment="Top" Margin="14" Padding="12,10" CornerRadius="10"
                                        Background="#CC000000" BorderBrush="{DynamicResource CardStroke}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="STATS LIVE" FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBBrush}" Margin="0,0,0,6"/>
                                        <TextBlock x:Name="StatsText" FontFamily="Consolas, monospace" FontSize="12"
                                                   Foreground="{DynamicResource TextBrush}" Text="—"/>
                                    </StackPanel>
                                </Border>

                                <!-- ===== OSD (auto-hide) ===== -->
                                <Grid x:Name="Osd" Opacity="0" IsHitTestVisible="False">
                                    <!-- top : title -->
                                    <Border VerticalAlignment="Top" Padding="24,16,24,32" IsHitTestVisible="False">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#D9000000" Offset="0"/>
                                                <GradientStop Color="#00000000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel>
                                            <TextBlock x:Name="TopTitle" FontSize="20" FontWeight="Bold"
                                                       Foreground="White" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="TopSubtitle" FontSize="12" Margin="0,3,0,0"
                                                       Foreground="#FFCBB8FF" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- bottom : controls -->
                                    <Border x:Name="OsdBottomChrome" VerticalAlignment="Bottom" Padding="20,28,20,16"
                                            >
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0"/>
                                                <GradientStop Color="#B8000000" Offset="0.38"/>
                                                <GradientStop Color="#F0000000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="OsdBottomOffset"/>
                                        </Border.RenderTransform>
                                        <StackPanel>
                                            <!-- quick video controls -->
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                                            <StackPanel x:Name="OsdUpscaleRow" Orientation="Horizontal" VerticalAlignment="Center"
                                                        Visibility="Collapsed">
                                                <Path Data="M 0,11 L 0,0 L 11,0 M 7,4 L 11,0 L 7,0 M 0,11 L 11,11 L 11,0"
                                                      Stroke="{DynamicResource AccentSoftBrush}" StrokeThickness="1.3" Stretch="Uniform"
                                                      Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Upscaling" FontSize="11" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" Margin="0,0,10,0"/>
                                                <ComboBox x:Name="OsdUpscaleCombo" Width="210" Height="30"
                                                          Style="{StaticResource FieldCombo}"
                                                          SelectionChanged="OsdUpscale_Changed"
                                                          ToolTip="Méthode d'upscaling (s'applique en direct)"/>
                                            </StackPanel>
                                            <StackPanel x:Name="OsdElyColorRow" Orientation="Horizontal" VerticalAlignment="Center"
                                                        Margin="18,0,0,0" Visibility="Collapsed">
                                                <Path Data="M 7,0 C 10.8,0 14,3.2 14,7 C 14,10.8 10.8,14 7,14 C 3.2,14 0,10.8 0,7 C 0,3.2 3.2,0 7,0 Z M 7,2 L 7,12"
                                                      Stroke="#FFFFC46B" StrokeThickness="1.25" Stretch="Uniform"
                                                      Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="ELYCOLOR" FontSize="11" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" Foreground="#FFFFE0B0" Margin="0,0,10,0"/>
                                                <ComboBox x:Name="OsdElyColorCombo" Width="220" Height="30"
                                                          Style="{StaticResource FieldCombo}"
                                                          SelectionChanged="OsdElyColor_Changed"
                                                          ToolTip="Filtre image ELYCOLOR (s'applique en direct)"/>
                                            </StackPanel>
                                            <StackPanel x:Name="OsdElySoundRow" Orientation="Horizontal" VerticalAlignment="Center"
                                                        Margin="18,0,0,0" Visibility="Collapsed">
                                                <Path Data="M 1,8 L 4,8 L 8,4 L 8,12 L 4,8 M 11,5 Q 14,8 11,11"
                                                      Stroke="#FF7DF9FF" StrokeThickness="1.35" Stretch="Uniform"
                                                      Width="15" Height="15" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <CheckBox x:Name="OsdElySoundEnableSwitch" Style="{StaticResource Switch}"
                                                          Content="ELYSOUND+" Margin="0,0,10,0"
                                                          Click="ElySoundEnabled_Changed"
                                                          ToolTip="Active/désactive tout le post-processing audio en direct"/>
                                                <ComboBox x:Name="OsdElySoundCombo" Width="210" Height="30"
                                                          Style="{StaticResource FieldCombo}"
                                                          SelectionChanged="OsdElySound_Changed"
                                                          ToolTip="Profil audio ELYSOUND+"/>
                                            </StackPanel>
                                            </StackPanel>

                                            <!-- epg (live) -->
                                            <ProgressBar x:Name="EpgProgress" Height="4" Minimum="0" Maximum="100" Value="0"
                                                         Margin="0,0,0,10" Visibility="Collapsed"
                                                         Foreground="{DynamicResource AccentABrush}"
                                                         Background="#33FFFFFF" BorderThickness="0"/>

                                            <Grid x:Name="OsdTransportRow">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel x:Name="OsdLeftTransportControls" Grid.Column="0"
                                                            Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button x:Name="StopBtn" Style="{StaticResource IconButton}" Click="Stop_Click">
                                                        <Rectangle Width="12" Height="12" Fill="White" RadiusX="2" RadiusY="2"/>
                                                    </Button>
                                                    <Button x:Name="SkipBackBtn" Style="{StaticResource IconButton}" Margin="8,0,0,0"
                                                            Click="SkipBack_Click" ToolTip="Reculer de 15 s (flèche gauche)" Visibility="Collapsed">
                                                        <TextBlock Text="-15" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                    </Button>
                                                    <Button x:Name="SkipFwdBtn" Style="{StaticResource IconButton}" Margin="8,0,0,0"
                                                            Click="SkipFwd_Click" ToolTip="Avancer de 15 s (flèche droite)" Visibility="Collapsed">
                                                        <TextBlock Text="+15" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                    </Button>
                                                </StackPanel>

                                                <StackPanel x:Name="OsdCenterTransportControls" Grid.Column="0" Grid.ColumnSpan="3" Panel.ZIndex="2"
                                                            Orientation="Horizontal" HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                    <Button x:Name="PreviousMediaBtn" Style="{StaticResource IconButton}"
                                                            Click="PreviousMedia_Click" ToolTip="Élément précédent">
                                                        <Path Data="M 4,3 L 6,3 L 6,13 L 4,13 Z M 13,3 L 13,13 L 7,8 Z"
                                                              Fill="White" Stretch="Uniform" Width="16" Height="16"/>
                                                    </Button>
                                                    <Button x:Name="PlayPauseBtn" Style="{StaticResource IconButton}" Margin="10,0"
                                                            Width="52" Height="52" Click="PlayPause_Click" ToolTip="Lecture / pause">
                                                        <Path x:Name="PlayPauseIcon" Data="M 5,3 L 12,8 L 5,13 Z" Fill="White"
                                                              Stretch="Uniform" Width="17" Height="17"/>
                                                    </Button>
                                                    <Button x:Name="NextMediaBtn" Style="{StaticResource IconButton}"
                                                            Click="NextMedia_Click" ToolTip="Élément suivant">
                                                        <Path Data="M 12,3 L 14,3 L 14,13 L 12,13 Z M 5,3 L 5,13 L 11,8 Z"
                                                              Fill="White" Stretch="Uniform" Width="16" Height="16"/>
                                                    </Button>
                                                </StackPanel>

                                                <StackPanel x:Name="OsdRightTransportControls" Grid.Column="2"
                                                            Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ComboBox x:Name="AudioCombo" Width="145" Height="34" Margin="0,0,12,0"
                                                              Style="{StaticResource FieldCombo}" DisplayMemberPath="Name"
                                                              SelectionChanged="Audio_Changed"
                                                              ToolTip="Piste audio" Visibility="Collapsed"/>
                                                    <ComboBox x:Name="SubtitleCombo" Width="155" Height="34" Margin="0,0,12,0"
                                                              Style="{StaticResource FieldCombo}" DisplayMemberPath="Name"
                                                              SelectionChanged="Subtitle_Changed"
                                                              ToolTip="Piste de sous-titres" Visibility="Collapsed"/>
                                                    <!-- Magpie/FSR externe : retiré de l'OSD (redondant avec l'upscaling
                                                         interne). Le bouton reste dans l'arbre, masqué, car le suivi
                                                         d'état Magpie (RefreshMagpieActiveState) le référence encore ;
                                                         l'activation se fait depuis les réglages vidéo. -->
                                                    <Button x:Name="UpscalerBtn" Style="{StaticResource IconButton}" Margin="0,0,12,0"
                                                            Visibility="Collapsed"
                                                            Click="UpscalerBtn_Click" ToolTip="Activer l'upscaling externe Magpie / FSR">
                                                        <TextBlock Text="FSR" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                    </Button>
                                                    <Button x:Name="StatsBtn" Style="{StaticResource IconButton}" Margin="0,0,12,0"
                                                            Click="StatsBtn_Click" ToolTip="Statistiques live">
                                                        <Path Data="M2,14 V8 M6,14 V4 M10,14 V9 M14,14 V2" Stroke="White" StrokeThickness="1.6"
                                                              Stretch="Uniform" Width="16" Height="16"/>
                                                    </Button>
                                                    <Path Data="M 0,4 L 3,4 L 7,1 L 7,11 L 3,8 L 0,8 Z M 9,3 Q 12,6 9,9"
                                                          Stroke="{DynamicResource TextBrush}" StrokeThickness="1.2"
                                                          Stretch="Uniform" Width="18" Height="18" Margin="0,0,10,0"/>
                                                    <Slider x:Name="VolumeSlider" Width="120" Minimum="0" Maximum="100" Value="75"
                                                            VerticalAlignment="Center" Style="{StaticResource VolumeSlider}"
                                                            ValueChanged="Volume_Changed"/>
                                                    <TextBlock x:Name="VolumePct" Text="75%" Width="40" Margin="8,0,0,0"
                                                               VerticalAlignment="Center" TextAlignment="Right" FontSize="12"
                                                               FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                                    <Button x:Name="FullscreenBtn" Style="{StaticResource IconButton}" Margin="16,0,0,0"
                                                            Click="Fullscreen_Click">
                                                        <Path Data="M 1,4 L 1,1 L 4,1 M 8,1 L 11,1 L 11,4 M 11,8 L 11,11 L 8,11 M 4,11 L 1,11 L 1,8"
                                                              Stroke="White" StrokeThickness="1.4" Stretch="Uniform" Width="16" Height="16"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                            <!-- seek (vod / episodes) — pinned to the very bottom of the chrome -->
                                            <Grid x:Name="SeekArea" Visibility="Collapsed" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="CurTime" Text="0:00" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextBrush}" Width="58"/>
                                                <Slider x:Name="SeekSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="0"
                                                        VerticalAlignment="Center" Style="{StaticResource VolumeSlider}"
                                                        IsMoveToPointEnabled="True"/>
